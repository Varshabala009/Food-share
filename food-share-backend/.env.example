# Azure Cosmos DB (Use when ready)
# MONGO_URI=mongodb+srv://username:password@foodshare-db.mongocluster.cosmos.azure.com/?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

